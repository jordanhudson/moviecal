{
  "name": "moviecal",
  "version": "1.0.0",
  "description": "Movie times scraper for various venues",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "scrape": "node dist/scrape.js",
    "migrate": "tsx src/db/migrate.ts",
    "clear": "tsx src/db/clear.ts",
    "drop": "tsx src/db/drop.ts",
    "repair": "tsx src/db/repair.ts",
    "backfill-letterboxd": "tsx src/db/backfill-letterboxd.ts",
    "audit-tmdb": "tsx src/db/audit-tmdb.ts",
    "rematch-tmdb": "tsx src/db/rematch-tmdb.ts",
    "build-tmdb-review": "tsx src/db/build-tmdb-review.ts",
    "server": "nodemon --watch src --ext ts --exec 'tsx src/server.ts'",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "scraper",
    "movies",
    "cinema"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "nodemon": "^3.1.14",
    "prettier": "3.8.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "8.62.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.8",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.3",
    "kysely": "^0.28.9",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "puppeteer": "^23.11.1"
  }
}
